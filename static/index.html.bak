<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Falafel Brothers — Task Tracker</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; line-height: 1.5; min-height: 100vh; }
        .container { max-width: 900px; margin: 0 auto; padding: 24px; }
        .header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 20px; margin-bottom: 16px; border-bottom: 1px solid #334155; flex-wrap: wrap; gap: 12px; }
        .header h1 { font-size: 22px; font-weight: 700; }
        .header h1 span { color: #3b82f6; }
        .stats-bar { display: flex; gap: 12px; font-size: 12px; flex-wrap: wrap; }
        .stat-pill { background: #1e293b; border: 1px solid #334155; border-radius: 8px; padding: 4px 10px; white-space: nowrap; }
        .stat-pill.high { border-color: #ef4444; color: #fca5a5; }
        .stat-pill .count { font-weight: 700; }
        .filters { display: flex; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
        .filter-btn { background: transparent; color: #94a3b8; border: 1px solid transparent; padding: 5px 10px; border-radius: 6px; font-size: 12px; cursor: pointer; }
        .filter-btn:hover { background: #334155; }
        .filter-btn.active { background: #3b82f6; color: #fff; border-color: #3b82f6; }
        .filters select { background: #0f172a; border: 1px solid #475569; color: #e2e8f0; padding: 5px 10px; border-radius: 6px; font-size: 12px; margin-left: auto; }
        .task-item { border: 1px solid #334155; border-radius: 8px; margin-bottom: 6px; overflow: hidden; transition: background 0.15s; }
        .task-item.parent-done { border-color: #22c55e33; }
        .task-header { display: flex; align-items: center; padding: 12px; gap: 10px; cursor: pointer; }
        .task-header:hover { background: #334155; }
        .task-header.parent-done { opacity: 0.6; }
        .task-header.parent-done .task-title { text-decoration: line-through; }
        .task-content { flex: 1; min-width: 0; }
        .task-title { font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .task-meta { display: flex; gap: 6px; margin-top: 4px; flex-wrap: wrap; }
        .expand-btn { width: 24px; height: 24px; border: none; background: transparent; color: #64748b; cursor: pointer; border-radius: 4px; font-size: 10px; display: flex; align-items: center; justify-content: center; transition: transform 0.2s; flex-shrink: 0; }
        .expand-btn.expanded { transform: rotate(90deg); }
        .expand-btn.hidden { visibility: hidden; }
        .tag { font-size: 10px; padding: 2px 8px; border-radius: 4px; font-weight: 500; }
        .tag.priority-high { background: #7f1d1d; color: #fca5a5; }
        .tag.priority-medium { background: #713f12; color: #fde68a; }
        .tag.priority-low { background: #14532d; color: #bbf7d0; }
        .tag.category { background: #312e81; color: #c7d2fe; }
        .tag.due { background: #4c1d95; color: #ddd6fe; }
        .tag.overdue { background: #7f1d1d; color: #fca5a5; }
        .tag.project { background: #164e63; color: #a5f3fc; }
        .tag.subtask-count { background: #1e293b; color: #94a3b8; }
        .tag.done-tag { background: #14532d; color: #86efac; }
        .task-actions { display: flex; gap: 4px; flex-shrink: 0; opacity: 0; transition: opacity 0.15s; }
        .task-header:hover .task-actions { opacity: 1; }
        .action-btn { background: transparent; border: 1px solid #475569; color: #94a3b8; width: 26px; height: 26px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 12px; }
        .action-btn:hover { background: #475569; color: #fff; }
        .subtask-panel { border-top: 1px solid #334155; background: #1a2335; display: none; }
        .subtask-panel.open { display: block; }
        .subtask-list { padding: 4px 0; }
        .subtask-row { display: flex; align-items: center; padding: 8px 16px; gap: 10px; transition: background 0.1s; }
        .subtask-row:hover { background: #334155; }
        .subtask-row.subtask-done .subtask-title { text-decoration: line-through; opacity: 0.5; }
        .subtask-check { width: 20px; height: 20px; border: 2px solid #475569; border-radius: 50%; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 12px; transition: all 0.15s; color: transparent; }
        .subtask-check:hover { border-color: #3b82f6; }
        .subtask-check.checked { background: #22c55e; border-color: #22c55e; color: #fff; }
        .subtask-title { flex: 1; font-size: 13px; }
        .subtask-meta { display: flex; gap: 4px; flex-shrink: 0; align-items: center; font-size: 10px; }
        .sub-actions { display: flex; gap: 3px; flex-shrink: 0; opacity: 0; transition: opacity 0.15s; }
        .subtask-row:hover .sub-actions { opacity: 1; }
        .add-subtask { display: flex; align-items: center; padding: 8px 16px; gap: 6px; border-top: 1px solid #334155; flex-wrap: wrap; }
        .add-subtask input[type="text"] { flex: 1; min-width: 120px; background: #0f172a; border: 1px solid #475569; color: #e2e8f0; padding: 6px 10px; border-radius: 6px; font-size: 12px; }
        .add-subtask input[type="text"]:focus { outline: none; border-color: #3b82f6; }
        .add-subtask input[type="date"] { background: #0f172a; border: 1px solid #475569; color: #e2e8f0; padding: 6px 8px; border-radius: 6px; font-size: 12px; }
        .add-subtask select { background: #0f172a; border: 1px solid #475569; color: #e2e8f0; padding: 6px 8px; border-radius: 6px; font-size: 12px; }
        .empty-state { text-align: center; padding: 48px 20px; color: #64748b; }
        .btn { background: #3b82f6; color: #fff; border: none; padding: 8px 16px; border-radius: 8px; font-size: 14px; cursor: pointer; font-weight: 500; }
        .btn:hover { background: #2563eb; }
        .btn-sm { padding: 5px 10px; font-size: 12px; }
        .btn-ghost { background: transparent; color: #94a3b8; border: 1px solid #475569; }
        .btn-ghost:hover { background: #334155; }
        .btn-add-task { background: #16a34a; }
        .btn-add-task:hover { background: #15803d; }
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; align-items: flex-start; justify-content: center; overflow-y: auto; padding: 40px 16px; }
        .modal-overlay.show { display: flex; }
        .modal-content { background: #1e293b; border: 1px solid #475569; border-radius: 12px; padding: 24px; width: 100%; max-width: 520px; }
        .form-row { margin-bottom: 12px; }
        .form-row label { display: block; font-size: 11px; color: #94a3b8; margin-bottom: 3px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
        .form-row input, .form-row select, .form-row textarea { width: 100%; padding: 8px 12px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #e2e8f0; font-size: 14px; font-family: inherit; }
        .form-row textarea { resize: vertical; min-height: 50px; }
        .form-row input:focus, .form-row select:focus, .form-row textarea:focus { outline: none; border-color: #3b82f6; }
        .form-row.half { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .form-actions { display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap; align-items: center; }
        /* Subtask section in modal */
        .modal-subtasks { border-top: 1px solid #334155; margin-top: 16px; padding-top: 16px; }
        .modal-subtasks h3 { font-size: 13px; color: #94a3b8; margin-bottom: 10px; font-weight: 600; }
        .modal-subtask-list { max-height: 160px; overflow-y: auto; }
        .modal-subtask-item { display: flex; align-items: center; gap: 6px; padding: 4px 0; font-size: 13px; }
        .modal-subtask-item input[type="text"] { flex: 1; padding: 5px 8px; font-size: 12px; background: #0f172a; border: 1px solid #475569; color: #e2e8f0; border-radius: 6px; }
        .modal-subtask-item input[type="date"] { width: 110px; padding: 5px 8px; font-size: 12px; background: #0f172a; border: 1px solid #475569; color: #e2e8f0; border-radius: 6px; }
        .modal-subtask-item select { width: 80px; padding: 5px 6px; font-size: 12px; background: #0f172a; border: 1px solid #475569; color: #e2e8f0; border-radius: 6px; }
        .modal-subtask-item .remove-sub { background: transparent; border: none; color: #94a3b8; cursor: pointer; font-size: 14px; padding: 2px 6px; }
        .modal-subtask-item .remove-sub:hover { color: #ef4444; }
        .add-subtask-row { display: flex; gap: 6px; margin-top: 8px; }
        .add-subtask-row input { flex: 1; padding: 5px 8px; font-size: 12px; background: #0f172a; border: 1px solid #475569; color: #e2e8f0; border-radius: 6px; }
        .add-subtask-row input:focus { outline: none; border-color: #3b82f6; }
        .progress-bar { height: 3px; background: #334155; border-radius: 2px; margin-top: 6px; overflow: hidden; width: 72px; }
        .progress-fill { height: 100%; background: #22c55e; border-radius: 2px; transition: width 0.3s; }
        .spinner { width: 20px; height: 20px; border: 2px solid #475569; border-top-color: #3b82f6; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 40px auto; }
        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🦊 <span>Task</span> Tracker</h1>
            <div class="stats-bar">
                <div class="stat-pill"><span class="count" id="stat-active">0</span> active</div>
                <div class="stat-pill high"><span class="count" id="stat-high">0</span> high</div>
                <div class="stat-pill"><span class="count" id="stat-overdue">0</span> overdue</div>
                <button class="btn btn-sm" onclick="showAddProject()">+ Project</button>
            </div>
        </div>
        <div class="filters">
            <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
            <button class="filter-btn" onclick="setFilter('todo', this)">Todo</button>
            <button class="filter-btn" onclick="setFilter('in-progress', this)">In Progress</button>
            <button class="filter-btn" onclick="setFilter('done', this)">Done</button>
            <select id="filter-category" onchange="filterByCategory(this.value)">
                <option value="">All Categories</option>
            </select>
        </div>
        <div id="task-list"><div class="spinner"></div></div>
    </div>

    <!-- Add/Edit Modal with inline subtasks -->
    <div class="modal-overlay" id="modal-add">
        <div class="modal-content">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                <h2 id="modal-title" style="font-size:16px;">New Project</h2>
                <button class="btn btn-ghost btn-sm" onclick="hideModal()">✕</button>
            </div>
            <form onsubmit="submitForm(event)">
                <input type="hidden" id="form-id" value="">
                <div class="form-row">
                    <label>Project Title *</label>
                    <input type="text" id="form-title" required placeholder="e.g. Update Foodex 2026 landing page">
                </div>
                <div class="form-row">
                    <label>Description</label>
                    <textarea id="form-description" placeholder="Details..."></textarea>
                </div>
                <div class="form-row half">
                    <div>
                        <label>Priority</label>
                        <select id="form-priority">
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                        </select>
                    </div>
                    <div>
                        <label>Category</label>
                        <select id="form-category"></select>
                    </div>
                </div>
                <div class="form-row half">
                    <div>
                        <label>Due Date *</label>
                        <input type="date" id="form-due-date" required>
                    </div>
                    <div>
                        <label>Project Tag</label>
                        <input type="text" id="form-project" placeholder="e.g. Foodex 2026">
                    </div>
                </div>

                <!-- Inline subtasks -->
                <div class="modal-subtasks">
                    <h3>Subtasks <span style="font-weight:400;font-size:11px;color:#64748b;">(optional)</span></h3>
                    <div class="modal-subtask-list" id="modal-subs"></div>
                    <div class="add-subtask-row">
                        <input type="text" id="modal-sub-input" placeholder="Task name...">
                        <input type="date" id="modal-sub-date" title="Due date (optional)">
                        <select id="modal-sub-priority">
                            <option value="low">Low</option>
                            <option value="medium" selected>Mid</option>
                            <option value="high">High</option>
                        </select>
                        <button type="button" class="btn btn-sm btn-add-task" onclick="addModalSubtask()">+</button>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn" id="form-submit-btn">Create Project</button>
                    <button type="button" class="btn btn-ghost" onclick="hideModal()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const API = '/api';
        let categories = {};
        let currentFilter = 'all';
        let currentCat = '';
        let expandedParents = new Set();
        let modalSubtasks = [];  // [{ title, due_date, priority }]

        async function init() {
            const resp = await fetch(`${API}/categories`);
            categories = await resp.json();
            const catSel = document.getElementById('form-category');
            const filterCat = document.getElementById('filter-category');
            for (const [id, name] of Object.entries(categories)) {
                catSel.appendChild(new Option(name, id));
                filterCat.appendChild(new Option(name, id));
            }
            loadTasks();
        }

        async function loadTasks() {
            const list = document.getElementById('task-list');
            list.innerHTML = '<div class="spinner"></div>';
            let url = `${API}/todos/root?`;
            if (currentFilter !== 'all') url += `status=${currentFilter}&`;
            if (currentCat) url += `category_id=${currentCat}&`;
            try {
                const [tasks, stats] = await Promise.all([
                    fetch(url).then(r => r.json()),
                    fetch(`${API}/stats`).then(r => r.json()),
                ]);
                document.getElementById('stat-active').textContent = stats.active_todos;
                document.getElementById('stat-high').textContent = stats.high_priority;
                document.getElementById('stat-overdue').textContent = stats.overdue;
                if (!tasks.length) {
                    list.innerHTML = '<div class="empty-state">No tasks yet. Create a project to get started.</div>';
                    return;
                }
                list.innerHTML = '';
                const now = new Date().toISOString().slice(0, 10);
                for (const t of tasks) {
                    const isDone = t.status === 'done';
                    const isOverdue = t.due_date && t.due_date < now && !isDone;
                    const prog = t.subtask_count && t.subtask_count.total > 0
                        ? Math.round((t.subtask_count.done / t.subtask_count.total) * 100) : 0;
                    const hasSubs = t.subtask_count && t.subtask_count.total > 0;

                    const el = document.createElement('div');
                    el.className = `task-item ${isDone ? 'parent-done' : ''}`;
                    el.id = `parent-${t.id}`;
                    el.innerHTML = `
                        <div class="task-header ${isDone ? 'parent-done' : ''}" onclick="toggleParent(${t.id})">
                            <button class="expand-btn ${hasSubs ? (expandedParents.has(t.id) ? 'expanded' : '') : 'hidden'}" onclick="event.stopPropagation(); toggleParent(${t.id})">▶</button>
                            <div class="task-content">
                                <div class="task-title">${esc(t.title)}</div>
                                <div class="task-meta">
                                    <span class="tag priority-${t.priority}">${t.priority}</span>
                                    ${t.category_name ? `<span class="tag category">${esc(t.category_name)}</span>` : ''}
                                    ${t.due_date ? `<span class="tag ${isOverdue ? 'overdue' : 'due'}">${t.due_date}</span>` : ''}
                                    ${t.project ? `<span class="tag project">${esc(t.project)}</span>` : ''}
                                    ${isDone ? '<span class="tag done-tag">✓ done</span>' : ''}
                                    ${hasSubs ? `<span class="tag subtask-count">${t.subtask_count.done}/${t.subtask_count.total}</span>` : ''}
                                    ${hasSubs ? `<div class="progress-bar"><div class="progress-fill" style="width:${prog}%"></div></div>` : ''}
                                </div>
                            </div>
                            <div class="task-actions" onclick="event.stopPropagation()">
                                <button class="action-btn" title="Edit" onclick="editTask(${t.id})">✎</button>
                                <button class="action-btn" title="Delete" onclick="deleteTask(${t.id})">🗑</button>
                            </div>
                        </div>
                        <div class="subtask-panel ${expandedParents.has(t.id) ? 'open' : ''}" id="panel-${t.id}">
                            <div class="subtask-list" id="subs-${t.id}">
                                ${expandedParents.has(t.id) ? '<div class="spinner" style="margin:12px auto;width:14px;height:14px;"></div>' : ''}
                            </div>
                            <div class="add-subtask">
                                <input type="text" placeholder="Add task..." id="sub-input-${t.id}" onkeydown="if(event.key==='Enter'){event.preventDefault();addSubtask(${t.id})}">
                                <input type="date" id="sub-date-${t.id}" title="Due (optional)">
                                <select id="sub-prior-${t.id}">
                                    <option value="low">Low</option>
                                    <option value="medium" selected>Mid</option>
                                    <option value="high">High</option>
                                </select>
                                <button class="btn btn-sm btn-add-task" onclick="addSubtask(${t.id})">Add</button>
                            </div>
                        </div>
                    `;
                    list.appendChild(el);
                    if (expandedParents.has(t.id)) loadSubtasks(t.id);
                }
            } catch(e) {
                list.innerHTML = `<div class="empty-state">Error loading tasks<br><small>${e.message}</small></div>`;
            }
        }

        async function loadSubtasks(parentId) {
            const container = document.getElementById(`subs-${parentId}`);
            try {
                const resp = await fetch(`${API}/todos?parent_id=${parentId}`);
                const subs = await resp.json();
                renderSubtasks(parentId, subs);
            } catch(e) {
                container.innerHTML = '<div style="padding:8px 16px;color:#64748b;font-size:12px;">Failed to load</div>';
            }
        }

        function renderSubtasks(parentId, subs) {
            const container = document.getElementById(`subs-${parentId}`);
            if (!subs.length) {
                container.innerHTML = '<div style="padding:8px 16px;color:#64748b;font-size:12px;">No subtasks yet</div>';
                return;
            }
            container.innerHTML = subs.map(s => {
                const isDone = s.status === 'done';
                return `
                    <div class="subtask-row ${isDone ? 'subtask-done' : ''}" id="sub-${s.id}">
                        <div class="subtask-check ${isDone ? 'checked' : ''}" onclick="toggleSubtask(${s.id}, this)">
                            ${isDone ? '✓' : ''}
                        </div>
                        <span class="subtask-title">${esc(s.title)}</span>
                        <div class="subtask-meta">
                            <span class="tag priority-${s.priority}">${s.priority}</span>
                            ${s.due_date ? `<span class="tag due">${s.due_date}</span>` : ''}
                        </div>
                        <div class="sub-actions">
                            <button class="action-btn" style="width:22px;height:22px;" onclick="deleteSubtask(${parentId}, ${s.id})" title="Delete">🗑</button>
                        </div>
                    </div>
                `;
            }).join('');
        }

        async function toggleParent(id) {
            if (expandedParents.has(id)) {
                expandedParents.delete(id);
            } else {
                expandedParents.add(id);
            }
            loadTasks();
        }

        async function toggleSubtask(subId, checkEl) {
            const isNowChecked = !checkEl.classList.contains('checked');
            // Optimistic toggle
            checkEl.classList.toggle('checked', isNowChecked);
            checkEl.textContent = isNowChecked ? '✓' : '';
            const row = checkEl.closest('.subtask-row');
            row.classList.toggle('subtask-done', isNowChecked);
            try {
                if (isNowChecked) {
                    await fetch(`${API}/todos/${subId}/complete`, { method: 'POST' });
                } else {
                    await fetch(`${API}/todos/${subId}/uncomplete`, { method: 'POST' });
                }
                const panel = checkEl.closest('.subtask-panel');
                const parentId = panel ? parseInt(panel.id.replace('panel-', '')) : null;
                if (parentId) {
                    await loadSubtasks(parentId);
                    refreshParentProgress(parentId);
                }
                loadTasks();
            } catch(e) { alert('Error'); loadTasks(); }
        }

        async function addSubtask(parentId) {
            const input = document.getElementById(`sub-input-${parentId}`);
            const dateInput = document.getElementById(`sub-date-${parentId}`);
            const title = input.value.trim();
            if (!title) return;
            const priority = document.getElementById(`sub-prior-${parentId}`).value;
            const dueDate = dateInput.value || null;
            try {
                await fetch(`${API}/todos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, priority, parent_id: parentId, due_date: dueDate }),
                });
                input.value = '';
                dateInput.value = '';
                await loadSubtasks(parentId);
                refreshParentProgress(parentId);
                loadTasks();
            } catch(e) { alert('Error adding task'); }
        }

        async function deleteSubtask(parentId, subId) {
            if (!confirm('Delete this subtask?')) return;
            try {
                await fetch(`${API}/todos/${subId}`, { method: 'DELETE' });
                await loadSubtasks(parentId);
                refreshParentProgress(parentId);
                loadTasks();
            } catch(e) { alert('Error'); }
        }

        async function refreshParentProgress(parentId) {
            const resp = await fetch(`${API}/todos/root`);
            const todos = await resp.json();
            const parent = todos.find(t => t.id === parentId);
            if (parent && parent.subtask_count) {
                const el = document.getElementById(`parent-${parentId}`);
                if (!el) return;
                const countEl = el.querySelector('.tag.subtask-count');
                if (countEl) countEl.textContent = `${parent.subtask_count.done}/${parent.subtask_count.total}`;
                const progEl = el.querySelector('.progress-fill');
                if (progEl) progEl.style.width = `${Math.round((parent.subtask_count.done / parent.subtask_count.total) * 100)}%`;
                if (parent.status === 'done') {
                    el.classList.add('parent-done');
                    el.querySelector('.task-header').classList.add('parent-done');
                    if (countEl) { countEl.style.background = '#14532d'; countEl.textContent += ' ✓'; }
                }
            }
        }

        async function deleteTask(id) {
            if (!confirm('Delete this project and all subtasks?')) return;
            try { await fetch(`${API}/todos/${id}`, { method: 'DELETE' }); loadTasks(); }
            catch(e) { alert('Error'); }
        }

        function setFilter(f, btn) {
            currentFilter = f;
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            loadTasks();
        }

        function filterByCategory(val) { currentCat = val; loadTasks(); }

        // Modal
        function showAddProject() {
            document.getElementById('modal-title').textContent = 'New Project';
            document.getElementById('form-id').value = '';
            document.getElementById('form-title').value = '';
            document.getElementById('form-description').value = '';
            document.getElementById('form-priority').value = 'medium';
            document.getElementById('form-category').value = '';
            document.getElementById('form-due-date').value = '';
            document.getElementById('form-project').value = '';
            document.getElementById('form-submit-btn').textContent = 'Create Project';
            modalSubtasks = [];
            renderModalSubtasks();
            document.getElementById('modal-add').classList.add('show');
            setTimeout(() => document.getElementById('form-title').focus(), 50);
        }

        function editTask(id) {
            fetch(`${API}/todos/${id}`).then(r => r.json()).then(async t => {
                document.getElementById('modal-title').textContent = 'Edit Project';
                document.getElementById('form-id').value = t.id;
                document.getElementById('form-title').value = t.title;
                document.getElementById('form-description').value = t.description || '';
                document.getElementById('form-priority').value = t.priority || 'medium';
                document.getElementById('form-category').value = t.category_id || '';
                document.getElementById('form-due-date').value = t.due_date || '';
                document.getElementById('form-project').value = t.project || '';
                document.getElementById('form-submit-btn').textContent = 'Save Changes';
                // Load existing subtasks into modal
                modalSubtasks = (t.subtasks || []).map(s => ({
                    _id: s.id,
                    title: s.title,
                    due_date: s.due_date || '',
                    priority: s.priority || 'medium',
                }));
                renderModalSubtasks();
                document.getElementById('modal-add').classList.add('show');
            });
        }

        function hideModal() { document.getElementById('modal-add').classList.remove('show'); }

        function addModalSubtask() {
            const input = document.getElementById('modal-sub-input');
            const title = input.value.trim();
            if (!title) return;
            modalSubtasks.push({
                title,
                due_date: document.getElementById('modal-sub-date').value || '',
                priority: document.getElementById('modal-sub-priority').value,
            });
            input.value = '';
            document.getElementById('modal-sub-date').value = '';
            renderModalSubtasks();
            input.focus();
        }

        function removeModalSubtask(idx) {
            modalSubtasks.splice(idx, 1);
            renderModalSubtasks();
        }

        function renderModalSubtasks() {
            const list = document.getElementById('modal-subs');
            if (!modalSubtasks.length) {
                list.innerHTML = '<div style="font-size:12px;color:#64748b;">No subtasks added yet</div>';
                return;
            }
            list.innerHTML = modalSubtasks.map((s, i) => `
                <div class="modal-subtask-item">
                    <span style="color:#64748b;width:16px;">${i+1}.</span>
                    <span style="flex:1;font-size:13px;">${esc(s.title)}</span>
                    ${s.due_date ? `<span class="tag due" style="font-size:10px;">${s.due_date}</span>` : ''}
                    <span class="tag priority-${s.priority}" style="font-size:10px;">${s.priority}</span>
                    <button class="remove-sub" onclick="removeModalSubtask(${i})">✕</button>
                </div>
            `).join('');
        }

        async function submitForm(e) {
            e.preventDefault();
            const id = document.getElementById('form-id').value;
            const data = {
                title: document.getElementById('form-title').value,
                description: document.getElementById('form-description').value,
                priority: document.getElementById('form-priority').value,
                category_id: document.getElementById('form-category').value ? parseInt(document.getElementById('form-category').value) : null,
                project: document.getElementById('form-project').value || null,
                due_date: document.getElementById('form-due-date').value,
            };
            try {
                if (id) {
                    await fetch(`${API}/todos/${id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data),
                    });
                    // Update subtasks: for now just add new ones that don't have _id
                    for (const s of modalSubtasks) {
                        if (!s._id) {
                            await fetch(`${API}/todos`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ title: s.title, priority: s.priority, parent_id: parseInt(id), due_date: s.due_date || null }),
                            });
                        }
                    }
                } else {
                    const created = await fetch(`${API}/todos`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data),
                    }).then(r => r.json());
                    // Add inline subtasks
                    for (const s of modalSubtasks) {
                        if (s.title.trim()) {
                            await fetch(`${API}/todos`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ title: s.title.trim(), priority: s.priority, parent_id: created.id, due_date: s.due_date || null }),
                            });
                        }
                    }
                }
            } catch(err) { alert('Error saving'); return; }
            hideModal();
            loadTasks();
        }

        function esc(str) { const d = document.createElement('div'); d.textContent = str; return d.innerHTML; }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') hideModal();
            if (e.key === 'n' && e.metaKey) { e.preventDefault(); showAddProject(); }
        });

        init();
    </script>
</body>
</html>
